# Comma-separated absolute paths to watch
WATCH_FOLDERS=/path/to/watch1,/path/to/watch2

# Comma-separated file extensions (no dots)
WATCH_EXTENSIONS=doc,pdf,txt

# Comma-separated chokidar events to react to
WATCH_EVENTS=add,unlink,change

# Seconds to wait after last event before firing command (debounce)
DEBOUNCE_SECONDS=30

# How often chokidar polls the filesystem (seconds) — keep >= 5 for CIFS
POLL_INTERVAL_SECONDS=10

# The command to run when debounce expires — watcher doesn't care what this does
# Example for Plex partial rescan:
# ON_CHANGE_COMMAND=curl -s "http://192.168.3.9:32400/library/sections/1/refresh?X-Plex-Token=YOUR_TOKEN"
ON_CHANGE_COMMAND=echo "change detected"
