# ===========================================================================
# MQTT broker (shared by publisher and subscriber)
# ===========================================================================

MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPIC=file-watcher/change

# Credentials (leave empty for anonymous / dev brokers)
MQTT_USERNAME=file-watcher
MQTT_PASSWORD=

# ===========================================================================
# Publisher config — watches filesystem and publishes events to MQTT
# ===========================================================================

# Comma-separated absolute paths to watch
WATCH_FOLDERS=/path/to/watch1,/path/to/watch2

# Comma-separated file extensions (no dots) — leave empty to watch all files
WATCH_EXTENSIONS=

# Comma-separated basename globs to ignore. Default filters out macOS AppleDouble
# metadata files (._*) that appear when copying from a Mac to an SMB/CIFS share.
# Set to an empty string to disable all ignores.
WATCH_IGNORE_PATTERNS=._*

# Comma-separated chokidar events to react to
WATCH_EVENTS=add,unlink,change

# Use polling mode — often required for CIFS/SMB mounts due to lack of inotify support (default: true)
USE_POLLING=true

# How often chokidar polls the filesystem (seconds) — keep >= 5 for CIFS
POLL_INTERVAL_SECONDS=10

# File must be stable (no size changes) for this many seconds before the publisher
# emits an `add` event (and, in `await-write-finish` mode, a `change` event too).
# Prevents partial events during slow CIFS copies. Default: 60s.
STABILITY_THRESHOLD_SECONDS=60

# How stability is enforced:
#   add-only            — only new files wait for stability; change/unlink events fire
#                         immediately (best for editors like OneTagger that rewrite in
#                         place). Default.
#   await-write-finish  — chokidar gates both add AND change events on stability. Safer
#                         for environments where edits happen in many small writes, but
#                         adds STABILITY_THRESHOLD_SECONDS of latency to every change.
STABILITY_MODE=add-only

# ===========================================================================
# Subscriber config — listens to MQTT events, debounces, and runs a command
# ===========================================================================

# Comma-separated path prefixes to filter on — leave empty to accept all paths
PATH_PREFIXES=

# Seconds to wait after last matching event before firing command (debounce)
DEBOUNCE_SECONDS=30

# The command to run when debounce expires — receives CHANGED_PATHS env var
# (newline-separated absolute host paths). Keep file-watcher agnostic — point
# this at an external orchestrator that owns any domain-specific logic.
ON_CHANGE_COMMAND=echo "change detected"
