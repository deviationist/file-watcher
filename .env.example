# ===========================================================================
# MQTT broker (shared by publisher and subscriber)
# ===========================================================================

MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPIC=file-watcher/change

# ===========================================================================
# Publisher config — watches filesystem and publishes events to MQTT
# ===========================================================================

# Comma-separated absolute paths to watch
WATCH_FOLDERS=/path/to/watch1,/path/to/watch2

# Comma-separated file extensions (no dots) — leave empty to watch all files
WATCH_EXTENSIONS=

# Comma-separated chokidar events to react to
WATCH_EVENTS=add,unlink,change

# How often chokidar polls the filesystem (seconds) — keep >= 5 for CIFS
POLL_INTERVAL_SECONDS=10

# ===========================================================================
# Subscriber config — listens to MQTT events, debounces, and runs a command
# ===========================================================================

# Comma-separated path prefixes to filter on — leave empty to accept all paths
PATH_PREFIXES=

# Seconds to wait after last matching event before firing command (debounce)
DEBOUNCE_SECONDS=30

# The command to run when debounce expires — receives CHANGED_PATHS env var
ON_CHANGE_COMMAND=echo "change detected"
